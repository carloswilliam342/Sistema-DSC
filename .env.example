# Configurações do Banco de Dados (MySQL)
# DB_USER/DB_PASSWORD é o usuário "leve" que o app usa em runtime: só precisa
# de DML (SELECT/INSERT/UPDATE/DELETE), nunca DDL.
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=dsc_ifma

# Usuário com privilégio de DDL (CREATE/ALTER/DROP), usado só pelo serviço
# `migrate` pra rodar as migrations. Se não definidos, cai no mesmo usuário
# do app acima (comportamento anterior). Em dev, o docker-compose.override.yml
# já cria esse usuário automaticamente (dsc_migrate); não precisa configurar
# nada aqui pra rodar local.
DB_MIGRATE_USER=
DB_MIGRATE_PASSWORD=

# Configurações de API de IA (Gemini)
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_api_do_gemini_aqui

# Redis (armazena as sessões de login). Em dev, sobe via docker-compose.override.yml,
# sem senha. Em produção, aponta para um servidor Redis externo/gerenciado; se o
# ACL exigir autenticação, preencha REDIS_USERNAME/REDIS_PASSWORD (o usuário deve
# ter acesso liberado ao padrão de chave dsc:sess:*).
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# Chave usada para assinar o cookie de sessão (gere uma aleatória, ex: openssl rand -hex 32)
SESSION_SECRET=

# Outras configurações (Opcional)
NODE_ENV=development
PORT=3000

# Prefixo de subdiretório em que a aplicação é servida (ex: /dsc se rodar em
# fabrica.ifma.edu.br/dsc). Deixe vazio para servir na raiz do domínio.
BASE_PATH=
